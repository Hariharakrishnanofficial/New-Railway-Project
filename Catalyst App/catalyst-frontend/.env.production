# Production environment - Catalyst Functions Backend
# Leave blank to use DEPLOYED_BACKEND constant in api.js (Catalyst function URL)
VITE_API_BASE_URL=
VITE_ENV=production
VITE_APP_NAME=Railway Ticketing System
VITE_APP_VERSION=2.0.0

# Feature flags
VITE_ENABLE_AI_CHAT=true
VITE_ENABLE_ANALYTICS=true

# Debug (disabled in production)
VITE_DEBUG=false
