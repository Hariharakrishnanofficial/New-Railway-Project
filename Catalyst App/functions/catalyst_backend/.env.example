# ═══════════════════════════════════════════════════════════════
#  Railway Ticketing System — Environment Configuration Template
#  Copy to .env and fill in your values. NEVER commit .env.
#  Database: Zoho Catalyst CloudScale (ZCQL)
# ═══════════════════════════════════════════════════════════════

# ── AI APIs (NEVER hardcode keys in source code) ───────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── JWT Security ──────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=replace_with_a_long_random_string_at_least_64_chars
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_DAYS=7

# ── Flask ─────────────────────────────────────────────────────
APP_ENVIRONMENT=production
SECRET_KEY=replace_with_a_random_secret_key

# ── CORS (comma-separated allowed origins; * for dev only) ───
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# ── Auth ─────────────────────────────────────────────────────
ADMIN_EMAIL=admin@admin.com
ADMIN_DOMAIN=admin.com
ADMIN_SETUP_KEY=railadmin@2026

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_AUTH=10
RATE_LIMIT_WINDOW=900

# ── Cache TTLs (seconds) ──────────────────────────────────────
CACHE_TTL_TRAINS=3600
CACHE_TTL_STATIONS=86400
