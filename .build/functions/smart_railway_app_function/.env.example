# ═══════════════════════════════════════════════════════════════
#  Smart Railway Ticketing System — Environment Configuration
#  Copy to .env and customize. NEVER commit .env to version control.
#  Database: Zoho Catalyst CloudScale (ZCQL)
# ═══════════════════════════════════════════════════════════════

# ══ SESSION MANAGEMENT (NEW - replaces JWT) ════════════════════
# Secret key for CSRF token signing. Generate with:
#   python -c "import secrets; print(secrets.token_hex(64))"
SESSION_SECRET=your_session_secret_key_here_at_least_64_chars

# Session timeout in hours (default: 24)
SESSION_TIMEOUT_HOURS=24

# Idle timeout in hours - session expires if inactive (default: 6)
SESSION_IDLE_TIMEOUT_HOURS=6

# Maximum concurrent sessions per user (default: 3)
MAX_CONCURRENT_SESSIONS=3

# Session cookie name (default: railway_sid)
SESSION_COOKIE_NAME=railway_sid

# Session cookie settings (for production, use Secure=true)
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Strict

# CSRF token length in bytes (default: 32, produces 43-char token)
CSRF_TOKEN_LENGTH=32

# CSRF header name (default: X-CSRF-Token)
CSRF_HEADER_NAME=X-CSRF-Token

# ══ AI APIs (NEVER hardcode keys) ══════════════════════════════
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ══ JWT SECURITY (DEPRECATED - will be removed) ════════════════
# Keep these for migration period only. Remove once session
# authentication is fully deployed.
JWT_SECRET_KEY=replace_with_a_long_random_string_at_least_64_chars
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_DAYS=7

# ══ Flask ══════════════════════════════════════════════════════
APP_ENVIRONMENT=production
SECRET_KEY=replace_with_a_random_secret_key

# ══ CORS (comma-separated origins; * for dev only) ═════════════
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# ══ Auth Admin Settings ════════════════════════════════════════
ADMIN_EMAIL=admin@admin.com
ADMIN_DOMAIN=admin.com
ADMIN_SETUP_KEY=railadmin@2026

# ══ Rate Limiting ══════════════════════════════════════════════
RATE_LIMIT_AUTH=10
RATE_LIMIT_WINDOW=900

# ══ Cache TTLs (seconds) ═══════════════════════════════════════
CACHE_TTL_TRAINS=3600
CACHE_TTL_STATIONS=86400

# ══ OTP EMAIL VERIFICATION ════════════════════════════════════════
# 🚨 CRITICAL: Add verified email address in Zoho Catalyst Console
#    1. Go to Catalyst Console → Email Service → Verified Senders
#    2. Verify an email address (e.g., noreply@smartrailway.com)
#    3. Use that verified email below
# ════════════════════════════════════════════════════════════════
# Verified sender email address for OTP emails
# MUST be verified in Zoho Catalyst Console before use
CATALYST_FROM_EMAIL=krishnan.hari@zappyworks.com

# OTP expiry time in minutes (default: 15)
OTP_EXPIRY_MINUTES=15

# Maximum OTP verification attempts (default: 3)
OTP_MAX_ATTEMPTS=3

# Cooldown between OTP resend requests in seconds (default: 60)
OTP_RESEND_COOLDOWN_SECONDS=60

# Application name displayed in OTP emails
APP_NAME=Smart Railway

# ══ EMPLOYEE INVITATIONS ═══════════════════════════════════════════
# Invitation expiry in hours (default: 24)
INVITATION_EXPIRY_HOURS=24
