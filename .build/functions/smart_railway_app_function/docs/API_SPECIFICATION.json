{
  "info": {
    "title": "Smart Railway Ticketing System API",
    "version": "2.0.0",
    "description": "Complete REST API for Railway Ticketing System with CloudScale database"
  },
  "baseUrl": "http://localhost:9000",
  "authentication": {
    "type": "Bearer",
    "header": "Authorization",
    "format": "Bearer {token}"
  },
  "lookupReferences": {
    "User_ID": { "table": "Users", "field": "ROWID" },
    "Train_ID": { "table": "Trains", "field": "ROWID" },
    "Station_ID": { "table": "Stations", "field": "ROWID" },
    "Route_ID": { "table": "Train_Routes", "field": "ROWID" },
    "Booking_ID": { "table": "Bookings", "field": "ROWID" },
    "Parent_Module_ID": { "table": "Module_Master", "field": "ROWID" }
  },
