        }
      },
      "validate": {
        "method": "GET",
        "path": "/auth/validate",
        "auth": true,
        "response": {
          "status": "success",
          "data": {
            "user": {
              "id": "1001",
              "fullName": "John Doe",
              "email": "john.doe@example.com",
              "role": "User"
            }
          }
        }
      },
      "refresh": {
        "method": "POST",
        "path": "/auth/refresh",
