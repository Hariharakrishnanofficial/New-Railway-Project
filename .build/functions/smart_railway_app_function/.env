# ══ SESSION MANAGEMENT (NEW - replaces JWT) ════════════════════
# Secret key for CSRF token signing. Generate with:
#   python -c "import secrets; print(secrets.token_hex(64))"
SESSION_SECRET=3c25d48829d34e5a8f48c4d069719108e9d0e1e8b8426746be21007dd8d06ea7b06bba1688435751978fc6252c7c760a2364736e1aca7f29f3a665e67441c149

# Session timeout in hours (default: 24)
SESSION_TIMEOUT_HOURS=1

# Idle timeout in hours - session expires if inactive (default: 6)
SESSION_IDLE_TIMEOUT_HOURS=1

# Maximum concurrent sessions per user (default: 3)
MAX_CONCURRENT_SESSIONS=1

# Session cookie name (default: railway_sid)
SESSION_COOKIE_NAME=railway_sid

# Session cookie settings (for production, use Secure=true)
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Strict

# CSRF token length in bytes (default: 32, produces 43-char token)
CSRF_TOKEN_LENGTH=32

# CSRF header name (default: X-CSRF-Token)
CSRF_HEADER_NAME=X-CSRF-Token

# ══ AI APIs (NEVER hardcode keys) ══════════════════════════════
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ══ JWT SECURITY (DEPRECATED - will be removed) ════════════════
