# ══ Auth Admin Settings ════════════════════════════════════════
ADMIN_EMAIL=admin@admin.com
ADMIN_DOMAIN=admin.com
ADMIN_SETUP_KEY=railadmin@2026

# ══ Rate Limiting ══════════════════════════════════════════════
# For development: Higher limits to avoid blocking during testing
# For production: Use strict defaults (10 attempts per 15 minutes)
RATE_LIMIT_AUTH=1000
RATE_LIMIT_WINDOW=3600

# Forgot Password specific rate limiting
# For development: 100 attempts per hour
# For production: 5 attempts per hour recommended
RATE_LIMIT_FORGOT_PASSWORD=100
RATE_LIMIT_FORGOT_PASSWORD_WINDOW=3600

# ══ Cache TTLs (seconds) ═══════════════════════════════════════
CACHE_TTL_TRAINS=3600
CACHE_TTL_STATIONS=86400

# ══ OTP EMAIL VERIFICATION ════════════════════════════════════════
# 🚨 CRITICAL: Add verified email address in Zoho Catalyst Console
#    1. Go to Catalyst Console → Email Service → Verified Senders
#    2. Verify an email address (e.g., noreply@smartrailway.com)
#    3. Use that verified email below
# ════════════════════════════════════════════════════════════════
# Verified sender email address for OTP emails
# MUST be verified in Zoho Catalyst Console before use
CATALYST_FROM_EMAIL=krishnan.hari@zappyworks.com

# OTP expiry time in minutes (default: 15)
OTP_EXPIRY_MINUTES=2

# Maximum OTP verification attempts (default: 3)
OTP_MAX_ATTEMPTS=2

# Cooldown between OTP resend requests in seconds (default: 60)
OTP_RESEND_COOLDOWN_SECONDS=10

# Maximum resend attempts per hour (default: 3)
# After this limit, user must wait 1 hour before requesting more OTPs
OTP_MAX_RESEND_ATTEMPTS=3

# Application name displayed in OTP emails
APP_NAME=Smart Railway
